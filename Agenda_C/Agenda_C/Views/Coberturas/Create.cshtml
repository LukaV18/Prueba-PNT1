@model Agenda_C.Models.Cobertura

@{
    ViewData["Title"] = "Crear Cobertura";
}

<h1>➕ Crear Nueva Cobertura</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="NumeroCredencial" class="control-label">Número de Credencial</label>
                <input asp-for="NumeroCredencial" class="form-control" placeholder="Ej: 123456789" />
                <span asp-validation-for="NumeroCredencial" class="text-danger"></span>
                <small class="form-text text-muted">
                    El número de credencial debe ser único en el sistema.
                </small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Prestadora" class="control-label">Obra Social / Prestadora</label>
                <select asp-for="Prestadora" class="form-select" asp-items="ViewBag.Prestadoras">
                    <option value="">-- Seleccione una prestadora --</option>
                </select>
                <span asp-validation-for="Prestadora" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PacienteId" class="control-label">Paciente (Opcional)</label>
                <select asp-for="PacienteId" class="form-select" asp-items="ViewBag.PacienteId">
                    <option value="">-- Sin paciente asignado --</option>
                </select>
                <small class="form-text text-muted">
                    Puede asignar la cobertura a un paciente existente o dejarlo en blanco.
                </small>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-success btn-lg">
                    Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">
                    Volver al Listado
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}