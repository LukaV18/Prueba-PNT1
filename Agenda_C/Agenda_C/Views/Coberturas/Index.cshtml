@model IEnumerable<Agenda_C.Models.Cobertura>

@{
    ViewData["Title"] = "Coberturas";
}

<h1> Coberturas</h1>

<!-- Mensajes de TempData -->
@if (TempData["Mensaje"] != null)
{
    var tipoMensaje = TempData["TipoMensaje"]?.ToString() ?? "info";
    <div class="alert alert-@tipoMensaje alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">
        ➕ Crear Nueva Cobertura
    </a>
</p>

<table class="table table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>Número de Credencial</th>
            <th>Prestadora</th>
            <th>Paciente</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <strong>@item.NumeroCredencial</strong>
                </td>
                <td>
                    <span class="badge bg-info">@item.Prestadora</span>
                </td>
                <td>
                    @if (item.Paciente != null)
                    {
                        <span>@item.Paciente.NombreCompleto</span>
                    }
                    else
                    {
                        <span class="text-muted">Sin paciente asignado</span>
                    }
                </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Ver detalles">
                             Detalles
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Editar">
                             Editar
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Eliminar">
                             Eliminar
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
         No hay coberturas registradas en el sistema.
    </div>
}